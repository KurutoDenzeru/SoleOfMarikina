---
import Footer from "@/components/Footer.astro";
import MobileTopNavbar from "@/components/MobileTopNavbar.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="About | Sole of Marikina">
  <div class="min-h-screen bg-[#f3eee7] text-[#1b140e]">
    <section class="relative">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(60%_46%_at_50%_0%,rgba(156,98,53,0.16)_0%,rgba(156,98,53,0)_100%),linear-gradient(180deg,rgba(255,255,255,0.38)_0%,rgba(243,238,231,1)_62%)]"
        aria-hidden="true"
      ></div>

      <MobileTopNavbar
        leftAction={{
          type: "link",
          icon: "move-left",
          ariaLabel: "Back to homepage",
          href: "/",
          dynamicBack: true,
          className: "rounded-md",
        }}
        rightAction={{
          type: "button",
          icon: "search",
          ariaLabel: "Search store products",
          className: "rounded-md",
        }}
        centerImageSrc="/Logo/brand.webp"
        centerImageAlt="Sole of Marikina"
        centerImageClass="h-16 w-auto max-w-xs object-contain sm:h-16"
        containerClass="sticky top-0 z-40 grid grid-cols-[1fr_auto_1fr] items-center border-b border-black/5 bg-[#f3eee7]/90 px-6 pt-5 pb-3 text-black backdrop-blur-md sm:px-8 sm:pt-6 sm:pb-3"
      />

      <main class="relative z-10 mx-auto w-full max-w-[430px] px-6 pb-16 sm:px-8 md:max-w-3xl lg:max-w-5xl lg:px-10">
        <header class="pt-6 sm:pt-8 md:pt-10">
          <p class="text-xs font-semibold tracking-[0.24em] uppercase text-[#775030] sm:text-sm">
            About Template
          </p>
          <h1 class="mt-3 max-w-[10ch] text-4xl leading-[0.9] font-extrabold tracking-[-0.02em] text-[#2a1a11] sm:text-4xl md:text-5xl lg:text-6xl">
            Built From Craft
          </h1>
          <p class="mt-5 max-w-3xl text-sm leading-relaxed font-medium text-black/70 sm:text-base md:text-lg">
            This is a design boilerplate for your About page. You can replace this copy with your story,
            mission, and brand background once the final messaging is ready.
          </p>
        </header>

        <section class="mt-10 grid gap-5 sm:mt-12 lg:grid-cols-[1.2fr_0.8fr]">
          <article class="rounded-3xl border border-black/10 bg-white/85 p-6 shadow-sm sm:p-8">
            <p class="text-xs font-semibold tracking-[0.18em] uppercase text-[#8e6340] sm:text-sm">
              Brand Narrative
            </p>
            <h2 class="mt-3 text-2xl leading-tight font-bold sm:text-3xl md:text-4xl">The Story Section</h2>
            <p class="mt-4 text-sm leading-relaxed font-medium text-black/70 sm:text-base md:text-lg">
              Insert your full story here. This area is meant for your origin, what inspired the project, and
              how the platform supports Marikina shoemakers today.
            </p>
          </article>

          <article class="rounded-3xl border border-[#3a2416] bg-[#2b1b11] p-6 text-white shadow-xs sm:p-8">
            <p class="text-xs font-semibold tracking-[0.18em] uppercase text-[#d8a370] sm:text-sm">
              Quick Facts
            </p>
            <ul class="mt-4 space-y-4 text-sm font-medium sm:text-base">
              <li class="rounded-xl border border-white/15 bg-white/5 px-4 py-3">Founded in: [Year]</li>
              <li class="rounded-xl border border-white/15 bg-white/5 px-4 py-3">Location: Marikina, Philippines</li>
              <li class="rounded-xl border border-white/15 bg-white/5 px-4 py-3">Focus: Local shoe craftsmanship</li>
            </ul>
          </article>
        </section>

        <section class="mt-8 grid gap-5 md:mt-10 md:grid-cols-3">
          <article class="rounded-2xl border border-black/10 bg-white/80 p-5 sm:p-6">
            <p class="text-xs font-semibold tracking-[0.16em] uppercase text-[#8e6340]">Mission</p>
            <p class="mt-3 text-sm font-medium text-black/70 sm:text-base">Placeholder mission statement block.</p>
          </article>
          <article class="rounded-2xl border border-black/10 bg-white/80 p-5 sm:p-6">
            <p class="text-xs font-semibold tracking-[0.16em] uppercase text-[#8e6340]">Vision</p>
            <p class="mt-3 text-sm font-medium text-black/70 sm:text-base">Placeholder vision statement block.</p>
          </article>
          <article class="rounded-2xl border border-black/10 bg-white/80 p-5 sm:p-6">
            <p class="text-xs font-semibold tracking-[0.16em] uppercase text-[#8e6340]">Values</p>
            <p class="mt-3 text-sm font-medium text-black/70 sm:text-base">Placeholder core values summary block.</p>
          </article>
        </section>
      </main>
    </section>

    <Footer />
  </div>
</BaseLayout>
