---
import type { StoreSlug } from "@/lib/store-pages";
import Footer from "@/components/Footer.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import MobileTopNavbar from "@/components/MobileTopNavbar.astro";
import { getProductCatalogByStore } from "@/lib/products-catalog";

const storeSlug: StoreSlug = "seacrest";
const catalog = getProductCatalogByStore(storeSlug);

if (!catalog) {
  throw new Error("Seacrest product catalog is missing.");
}
---

<BaseLayout title="Seacrest | Their Products">
  <div class="flex min-h-screen flex-col">
    <section class="relative min-h-screen w-full overflow-x-clip bg-[#d8ae73]">
      <div
        class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
        style="background-image:url('/map/marikina_2k.png');"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-0 z-[5] bg-[linear-gradient(180deg,rgba(183,82,24,0.36)_0%,rgba(128,37,12,0.48)_44%,rgba(18,5,2,0.9)_74%,rgba(0,0,0,0.99)_100%)]"
        aria-hidden="true"
      >
      </div>

      <MobileTopNavbar
        leftAction={{
          type: "link",
          icon: "move-left",
          ariaLabel: "Back to previous page",
          href: `/stores/${storeSlug}/wtw`,
          dynamicBack: true,
          className: "rounded-md text-white",
        }}
        rightAction={{
          type: "button",
          icon: "search",
          ariaLabel: "Placeholder",
          className: "invisible pointer-events-none rounded-md",
        }}
        centerImageSrc={catalog.logo}
        centerImageAlt={catalog.logoAlt}
        centerImageClass="h-14 w-auto max-w-[180px] object-contain sm:h-16 sm:max-w-[220px]"
        containerClass="sticky top-0 z-40 grid grid-cols-[1fr_auto_1fr] items-center px-6 pt-5 pb-3 text-white sm:px-8 sm:pt-6 sm:pb-3"
      />

      <main
        class="relative z-20 mx-auto w-full max-w-[430px] px-6 pb-14 sm:px-8 sm:pb-16 md:max-w-3xl lg:max-w-6xl lg:px-10"
      >
        <h1
          class="mx-auto mt-10 max-w-[14ch] text-center text-6xl leading-[0.9] font-extrabold tracking-[-0.02em] text-white sm:mt-8 sm:max-w-md sm:text-6xl md:text-7xl"
        >
          THEIR PRODUCTS
        </h1>

        <div
          class="mt-8 grid grid-cols-2 gap-6 sm:mt-10 md:grid-cols-2 lg:grid-cols-3"
        >
          {
            catalog.products.map((product) => (
              <a
                href={`/stores/${storeSlug}/products/${product.slug}`}
                class="group block"
              >
                <article class="relative aspect-square overflow-hidden rounded-[2rem] border border-black/10 bg-[#F0F0F0] transition duration-200 group-hover:-translate-y-0.5">
                  <div
                    class="h-full w-full bg-cover bg-center"
                    style={`background-image:url('${product.image}'); background-size: cover; background-position: center;`}
                    role="img"
                    aria-label={product.name}
                  />
                </article>

                <div class="mt-3 px-1">
                  <p class="text-sm font-medium text-white leading-tight">
                    {product.name}
                  </p>
                  <p class="mt-1 text-lg font-extrabold text-white">
                    {product.price}
                  </p>
                </div>
              </a>
            ))
          }
        </div>
      </main>
    </section>

    <Footer />
  </div>
</BaseLayout>
