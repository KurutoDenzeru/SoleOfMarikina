---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MobileTopNavbar from "@/components/MobileTopNavbar.astro";
import { Skeleton } from "@/components/ui/skeleton";

const seacrestMapBackground = "/map/seacrest.png";
const products = [
  { name: "Topsider", price: "₱ 2,190", image: "/pictures/Seacrest/Topsider.jpg" },
  { name: "Slip On", price: "₱ 800-900", image: "/pictures/Seacrest/Slip-on.jpg" },
  { name: "Loafers", price: "₱ 1,700", image: "/pictures/Seacrest/Loafers.jpg" },
  { name: "Riderboots", price: "₱ 3,200", image: "/pictures/Seacrest/Riderboots.jpg" },
  { name: "Captoe", price: "₱ 4,000", image: "/pictures/Seacrest/Captoe.jpg" },
];
---

<BaseLayout title="Seacrest | Their Products">
  <section
    class="relative min-h-screen w-full overflow-x-hidden bg-[#160500] bg-cover bg-top bg-no-repeat sm:bg-center"
    style={`background-image:url('${seacrestMapBackground}');`}
  >
    <div
      class="fixed inset-0 z-0 pointer-events-none bg-[linear-gradient(180deg,rgba(232,129,33,0.82)_0%,rgba(176,67,10,0.8)_28%,rgba(95,26,4,0.88)_56%,rgba(21,6,1,0.95)_78%,rgba(0,0,0,1)_100%)]"
      aria-hidden="true"
    ></div>

    <MobileTopNavbar
      leftAction={{
        type: "link",
        icon: "move-left",
        ariaLabel: "Back to Souls Behind the Soles Story",
        href: "/stores/seacrest/sbts",
        dynamicBack: true,
        className: "rounded-md text-white",
      }}
      rightAction={{
        type: "button",
        icon: "search",
        ariaLabel: "Search store content",
        className: "rounded-md text-white",
      }}
      centerImageSrc="/Logo/Seacrest.webp"
      centerImageAlt="Seacrest"
      centerImageClass="h-16 w-auto max-w-xs object-contain sm:h-16"
      containerClass="sticky top-0 z-40 grid grid-cols-[1fr_auto_1fr] items-center px-6 pt-5 pb-3 text-white sm:px-8 sm:pt-6 sm:pb-3"
    />

    <main class="relative z-20 mx-auto w-full max-w-[430px] px-6 pb-12 sm:px-8 sm:pb-10 md:max-w-3xl lg:max-w-5xl">
      <h1 class="mx-auto mt-10 max-w-[14ch] text-center text-4xl leading-[0.9] font-extrabold tracking-[-0.02em] text-white sm:mt-8 sm:max-w-md sm:text-4xl md:text-5xl">
        THEIR PRODUCTS
      </h1>

      <div class="mt-8 grid gap-6 sm:mt-10 md:grid-cols-2">
        {
          products.map((product) => (
            <article
              class="group relative h-64 overflow-hidden rounded-[2rem] bg-black shadow-[0_8px_24px_rgba(0,0,0,0.35)] sm:h-72 lg:h-80"
            >
              <Skeleton className="absolute inset-0 h-full w-full rounded-[2rem]" />
              <img
                src={product.image}
                alt={product.name}
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
                loading="lazy"
                decoding="async"
                onload="this.previousElementSibling.style.display='none'"
              />
              <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.46)_0%,rgba(0,0,0,0.12)_42%,rgba(0,0,0,0.06)_100%)]" aria-hidden="true"></div>
              <div class="absolute top-5 left-5 text-left text-white leading-none">
                <p class="text-2xl font-extrabold sm:text-3xl lg:text-4xl">{product.name}</p>
                <p class="mt-0.5 text-xl font-extrabold sm:text-2xl lg:text-3xl">{product.price}</p>
              </div>
            </article>
          ))
        }
      </div>

      <div class="mt-12 flex flex-row items-center justify-between gap-4 sm:mt-16 sm:justify-center sm:gap-6">
        <h2 class="text-2xl font-extrabold text-white sm:text-4xl">STEP INTO STYLE</h2>
        <a
          href="https://ph.shp.ee/TiwGdqQ"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-10 shrink-0 items-center justify-center rounded-full bg-black px-6 text-sm font-bold text-white transition-transform hover:scale-105 active:scale-95 sm:h-12 sm:px-8 sm:text-lg"
        >
          Shop Now
        </a>
      </div>
    </main>
  </section>
</BaseLayout>
