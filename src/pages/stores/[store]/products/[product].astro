---
import type { StoreSlug } from "@/lib/store-pages";
import Footer from "@/components/Footer.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import MobileTopNavbar from "@/components/MobileTopNavbar.astro";
import { getProductCatalogByStore } from "@/lib/products-catalog";

export async function getStaticPaths() {
  return (["brads-trendies", "nico-angelo", "seacrest"] as StoreSlug[]).flatMap(
    (store) => {
      const catalog = getProductCatalogByStore(store);
    if (!catalog) return [];
    return catalog.products.map((product) => ({
      params: { store, product: product.slug },
    }));
    },
  );
}

const { store, product } = Astro.params as {
  store: StoreSlug;
  product: string;
};

const catalog = getProductCatalogByStore(store);

if (!catalog) {
  throw new Error(`Product catalog is missing for store: ${store}`);
}

const productEntry = catalog.products.find((item) => item.slug === product);

if (!productEntry) {
  throw new Error(`Product '${product}' not found for store: ${store}`);
}

const backHref = `/stores/${store}/their-products`;
const isNico = store === "nico-angelo";
const contactHref = catalog.contactUrl ?? productEntry.checkUrl;
const contactLabel = catalog.contactUrl ? "Contact Page" : "Check Product";
---

<BaseLayout title={`${catalog.logoAlt} | ${productEntry.name}`}>
  <div class="flex min-h-screen flex-col bg-[#F0F0F0] text-[#181818]">
    <MobileTopNavbar
      leftAction={{
        type: "link",
        icon: "move-left",
        ariaLabel: "Back to products listing",
        href: backHref,
        dynamicBack: true,
        className: "rounded-md text-black",
      }}
      rightAction={{
        type: "button",
        icon: "search",
        ariaLabel: "Placeholder",
        className: "invisible pointer-events-none rounded-md",
      }}
      centerImageSrc={catalog.logo}
      centerImageAlt={catalog.logoAlt}
      centerImageClass={`h-14 w-auto max-w-[200px] object-contain ${isNico ? "invert" : "invert"}`}
      containerClass="sticky top-0 z-40 grid grid-cols-[1fr_auto_1fr] items-center bg-[#F0F0F0] px-6 pt-5 pb-3 text-black transition-[background-color,backdrop-filter] duration-150 sm:px-8 sm:pt-6 sm:pb-3"
    />

    <main class="mx-auto flex w-full max-w-[1200px] flex-1 flex-col px-6 pb-16 pt-8 sm:px-8">
      <div class="mx-auto w-full max-w-[520px]">
        <img
          src={productEntry.image}
          alt={productEntry.name}
          loading="lazy"
          decoding="async"
          class="mx-auto h-72 w-full object-contain object-center sm:h-80 md:h-96"
        />

        <article class="mt-6 rounded-[2rem] bg-[#d7cfc6] p-7 text-[#1b140e] shadow-md">
          <div class="flex items-start justify-between gap-4">
            <h1 class="max-w-[13ch] text-3xl leading-[0.86] font-extrabold tracking-tight">
              {productEntry.name}
            </h1>
            <span class="pt-2 text-2xl leading-none font-extrabold">
              {productEntry.price}
            </span>
          </div>

          <p class="mt-4 text-base leading-snug font-semibold text-black/75">
            {productEntry.description}
          </p>

          <ul class="mt-4 space-y-2 text-base leading-snug font-bold text-black/75">
            {
              productEntry.bulletPoints.map((point) => (
                <li>• {point}</li>
              ))
            }
          </ul>

          {
            contactHref && (
              <div class="mt-6 flex justify-center">
                <a
                  href={contactHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-full bg-[#C86300] px-6 py-2 text-sm font-bold text-white transition-transform duration-150 hover:scale-[1.02] active:scale-95"
                >
                  {contactLabel}
                </a>
              </div>
            )
          }
        </article>
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>
