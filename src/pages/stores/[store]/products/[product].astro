---
import type { StoreSlug } from "@/lib/store-pages";
import Footer from "@/components/Footer.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getProductCatalogByStore } from "@/lib/products-catalog";

export async function getStaticPaths() {
  return (["brads-trendies", "nico-angelo", "seacrest"] as StoreSlug[]).flatMap(
    (store) => {
      const catalog = getProductCatalogByStore(store);
    if (!catalog) return [];
    return catalog.products.map((product) => ({
      params: { store, product: product.slug },
    }));
    },
  );
}

const { store, product } = Astro.params as {
  store: StoreSlug;
  product: string;
};

const catalog = getProductCatalogByStore(store);

if (!catalog) {
  throw new Error(`Product catalog is missing for store: ${store}`);
}

const productEntry = catalog.products.find((item) => item.slug === product);

if (!productEntry) {
  throw new Error(`Product '${product}' not found for store: ${store}`);
}

const backHref = `/stores/${store}/their-products`;
const isNico = store === "nico-angelo";
---

<BaseLayout title={`${catalog.logoAlt} | ${productEntry.name}`}>
  <div class="flex min-h-screen flex-col bg-[#F0F0F0] text-[#181818]">
    <header class="mx-auto w-full max-w-[1200px] px-6 pt-6 sm:px-8">
      <div class="flex items-center justify-between">
        <a
          href={backHref}
          aria-label="Back to products listing"
          class="inline-flex rounded-md p-1 text-black"
        >
          <span class="text-3xl leading-none">←</span>
        </a>
        <div class="flex flex-1 justify-center">
          <img
            src={catalog.logo}
            alt={catalog.logoAlt}
            class:list={[
              "h-10 w-auto object-contain",
              isNico ? "sm:h-12" : "sm:h-10",
            ]}
          />
        </div>
        <span class="w-10"></span>
      </div>
    </header>

    <main class="mx-auto flex w-full max-w-[1200px] flex-1 flex-col px-6 pb-16 pt-8 sm:px-8">
      <div class="mx-auto w-full max-w-[520px]">
        <img
          src={productEntry.image}
          alt={productEntry.name}
          loading="lazy"
          decoding="async"
          class="mx-auto h-56 w-full object-contain object-center"
        />

        <article class="mt-6 rounded-[2rem] bg-[#d7cfc6] p-7 text-[#1b140e]">
          <div class="flex items-start justify-between gap-4">
            <h1 class="max-w-[7ch] text-5xl leading-[0.86] font-extrabold tracking-tight">
              {productEntry.name}
            </h1>
            <span class="pt-2 text-4xl leading-none font-extrabold">
              {productEntry.price}
            </span>
          </div>

          <p class="mt-4 text-base leading-snug font-semibold text-black/75">
            {productEntry.description}
          </p>

          <ul class="mt-4 space-y-2 text-base leading-snug font-semibold text-black/75">
            {
              productEntry.bulletPoints.map((point) => (
                <li>• {point}</li>
              ))
            }
          </ul>

          {
            catalog.checkUrl && (
              <div class="mt-6 flex justify-center">
                <a
                  href={catalog.checkUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-full bg-[#C86300] px-6 py-2 text-sm font-bold text-white"
                >
                  Check Product
                </a>
              </div>
            )
          }
        </article>
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>
