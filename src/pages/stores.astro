---
import Footer from "@/components/Footer.astro";
import MobileTopNavbar from "@/components/MobileTopNavbar.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Skeleton } from "@/components/ui/skeleton";
import { storeOrder, storeProducts, stores } from "@/lib/store-pages";

const slugOrder = new Map(storeOrder.map((slug, index) => [slug, index]));

const toToken = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const storeLinks: Record<string, string> = {
  "brads-trendies":
    "https://shopee.ph/bnkclogs?entryPoint=ShopBySearch&searchKeyword=bnk+clogs",
  "nico-angelo": "https://www.facebook.com/profile.php?id=61580780770102",
  seacrest: "https://ph.shp.ee/TiwGdqQ",
};

const storesWithProducts = [...stores]
  .sort((a, b) => (slugOrder.get(a.slug) ?? 99) - (slugOrder.get(b.slug) ?? 99))
  .map((store) => ({
    ...store,
    link: storeLinks[store.slug] || `/stores/${store.slug}/their-products`,
    products: storeProducts[store.slug].map((product) => ({
      ...product,
      id: `${store.slug}-${toToken(product.name)}`,
      searchText:
        `${store.name} ${product.name} ${product.price}`.toLowerCase(),
    })),
  }));
---

<BaseLayout title="Stores | Their Products">
  <div class="min-h-screen bg-[#f6f2ec] text-[#17120d]">
    <section class="relative">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(60%_44%_at_50%_0%,rgba(212,150,75,0.16)_0%,rgba(212,150,75,0)_100%),linear-gradient(180deg,rgba(255,255,255,0.54)_0%,rgba(246,242,236,1)_52%)]"
        aria-hidden="true"
      >
      </div>
      <MobileTopNavbar
        leftAction={{
          type: "link",
          icon: "move-left",
          ariaLabel: "Back to homepage",
          href: "/",
          dynamicBack: true,
          className: "rounded-md",
        }}
        rightAction={{
          type: "button",
          icon: "search",
          ariaLabel: "Search store products",
          className: "rounded-md",
        }}
        centerImageSrc="/Logo/brand.webp"
        centerImageAlt="Sole of Marikina"
        centerImageClass="h-14 w-auto max-w-[220px] object-contain sm:h-22 sm:max-w-[260px]"
        containerClass="stores-sticky-nav sticky top-0 z-40 grid grid-cols-[1fr_auto_1fr] items-center px-6 pt-5 pb-3 text-black transition-[background-color,backdrop-filter] duration-200 sm:px-8 sm:pt-6 sm:pb-3"
      />

      <main
        class="relative z-10 mx-auto w-full max-w-[430px] px-6 pb-16 sm:px-8 md:max-w-3xl lg:max-w-5xl lg:px-10"
      >
        <header class="pt-6 sm:pt-8 md:pt-10">
          <p
            class="text-xs font-semibold tracking-[0.24em] uppercase text-[#6d4b2b] sm:text-sm"
          >
            Stores Landing
          </p>
          <h1
            class="mt-3 max-w-[12ch] text-4xl leading-[0.9] font-extrabold tracking-[-0.02em] text-[#1f150e] sm:text-4xl md:text-5xl lg:text-6xl"
          >
            Their Products
          </h1>
          <p
            class="mt-5 max-w-3xl text-sm leading-relaxed font-medium text-black/70 sm:text-base md:text-lg"
          >
            Explore product lines from Brad&apos;s Trendies, Nico Angelo, and
            Seacrest in one place. Use the search button in the navbar to
            instantly filter by store name or product.
          </p>
        </header>

        <section class="mt-10 space-y-10 sm:mt-12 md:space-y-12">
          {
            storesWithProducts.map((store) => (
              <article
                data-store-section
                data-store-name={store.name.toLowerCase()}
                class="overflow-hidden rounded-3xl border border-black/10 bg-white/88 shadow-[0_14px_38px_rgba(23,18,13,0.08)] backdrop-blur-sm"
              >
                <div class="flex flex-wrap items-center justify-between gap-4 border-b border-black/8 px-5 py-4 sm:px-7 sm:py-5">
                  <div>
                    <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[#8d6540] sm:text-sm">
                      {store.name}
                    </p>
                    <p class="mt-1 text-sm font-medium text-black/65 sm:text-base">
                      {store.products.length} products curated
                    </p>
                  </div>
                  <a
                    href={store.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center rounded-full border border-black/20 px-5 py-2 text-sm font-semibold text-black transition hover:border-black/40 hover:bg-black hover:text-white sm:text-base"
                  >
                    View Store
                  </a>
                </div>

                <div class="grid gap-4 p-4 sm:grid-cols-2 sm:gap-5 sm:p-6 lg:grid-cols-3">
                  {store.products.map((product) => (
                    <a
                      id={product.id}
                      href={store.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      data-product-card
                      data-search-text={product.searchText}
                      data-product-name={product.name}
                      data-store-name={store.name}
                      data-product-price={product.price}
                      class="group relative block h-64 overflow-hidden rounded-2xl border border-black/5 bg-black shadow-[0_10px_28px_rgba(0,0,0,0.24)] sm:h-72"
                    >
                      <Skeleton className="absolute inset-0 h-full w-full rounded-2xl" />
                      <img
                        src={product.image}
                        alt={`${store.name} - ${product.name}`}
                        class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-110"
                        loading="lazy"
                        decoding="async"
                        onload="this.previousElementSibling.style.display='none'"
                      />
                      <div
                        class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.56)_0%,rgba(0,0,0,0.12)_44%,rgba(0,0,0,0.9)_100%)]"
                        aria-hidden="true"
                      />
                      <div class="absolute inset-x-4 bottom-4 text-white sm:inset-x-5 sm:bottom-5">
                        <p class="text-2xl leading-none font-extrabold tracking-tight sm:text-3xl">
                          {product.name}
                        </p>
                        <p class="mt-1 text-base font-semibold text-white/95 sm:text-lg">
                          {product.price}
                        </p>
                      </div>
                    </a>
                  ))}
                </div>
              </article>
            ))
          }

          <div
            id="stores-empty-state"
            class="hidden rounded-3xl border border-dashed border-black/20 bg-white/70 px-6 py-12 text-center"
          >
            <p class="text-2xl font-bold text-[#1f150e] sm:text-3xl">
              No products found
            </p>
            <p class="mt-3 text-sm font-medium text-black/70 sm:text-base">
              Try another search term like <span class="font-semibold"
                >Seacrest</span
              > or
              <span class="font-semibold"> Topsider</span>.
            </p>
          </div>
        </section>
      </main>
    </section>

    <Footer />
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    if (window.__somStoresPageQueryFilterInitialized) return;
    window.__somStoresPageQueryFilterInitialized = true;

    const init = () => {
      const params = new URLSearchParams(window.location.search);
      const query = (params.get("q") || "").toLowerCase().trim();
      const cards = Array.from(
        document.querySelectorAll("[data-product-card]"),
      );
      const sections = Array.from(
        document.querySelectorAll("[data-store-section]"),
      );
      const emptyState = document.getElementById("stores-empty-state");
      if (!cards.length || !sections.length || !emptyState) return;

      let visibleCount = 0;
      cards.forEach((card) => {
        const searchable = card.getAttribute("data-search-text") || "";
        const isMatch = !query || searchable.includes(query);
        card.classList.toggle("hidden", !isMatch);
        if (isMatch) visibleCount += 1;
      });

      sections.forEach((section) => {
        const hasVisibleCards = section.querySelector(
          "[data-product-card]:not(.hidden)",
        );
        section.classList.toggle("hidden", !hasVisibleCards);
      });

      emptyState.classList.toggle("hidden", visibleCount > 0);
    };

    const handleScroll = () => {
      const nav = document.querySelector(".stores-sticky-nav");
      if (nav instanceof HTMLElement) {
        const hasScrolled = window.scrollY > 10;
        nav.style.backgroundColor = hasScrolled
          ? "rgba(246, 242, 236, 0.72)"
          : "transparent";
        nav.style.backdropFilter = hasScrolled ? "blur(10px)" : "none";
        nav.style.borderBottom = hasScrolled
          ? "1px solid rgba(0,0,0,0.05)"
          : "none";
      }
    };

    init();
    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();

    document.addEventListener("astro:page-load", () => {
      init();
      handleScroll();
    });
  })();
</script>
