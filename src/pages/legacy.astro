---
import { MoveLeft } from "lucide-react";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Footer from "@/components/Footer.astro";
import MobileTopNavbar from "@/components/MobileTopNavbar.astro";

const marikinaLegacyImageOne = "/landing/Marikina%201.png";
const marikinaLegacyImageTwo = "/landing/Marikina%202.png";
const donLaureanoImage = "/landing/Don%20Laureano%20Gueverra.jpg";
const shoeMuseumImage = "/landing/Marikina%20Shoe%20Museum.jpg";

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Stores", href: "/stores" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
---

<BaseLayout
  title="Marikina Shoe Legacy | Sole of Marikina"
  description="Learn the story of Marikina shoemaking, from Kapitan Moy to today's modern artisans."
>
  <div class="flex min-h-screen flex-col bg-[#050505] text-white">
    <section class="relative min-h-screen w-full overflow-x-clip bg-[#d8ae73]">
      <button
        id="legacy-menu-overlay"
        type="button"
        aria-label="Close menu"
        aria-hidden="true"
        class="pointer-events-none fixed inset-0 z-[55] bg-black/40 opacity-0 transition-opacity duration-300 ease-out"
      ></button>

      <aside
        id="legacy-mobile-sidebar"
        role="dialog"
        aria-modal="true"
        aria-hidden="true"
        aria-labelledby="legacy-mobile-sidebar-title"
        class="fixed left-0 top-0 z-[60] flex h-full w-[71%] max-w-[22rem] -translate-x-full flex-col overflow-y-auto bg-black/90 px-6 py-6 text-white transition-transform duration-300 ease-out"
      >
        <h2 id="legacy-mobile-sidebar-title" class="sr-only">
          Main navigation
        </h2>
        <div class="mb-16 flex items-center justify-start">
          <button
            id="legacy-menu-close"
            type="button"
            aria-label="Close navigation menu"
            class="inline-flex rounded-md p-1 text-white/95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
          >
            <MoveLeft className="size-8" />
          </button>
        </div>

        <nav aria-label="Main navigation" class="mt-1 flex-1">
          <ul class="space-y-7">
            {
              navLinks.map((link) => {
                const linkPath = link.href.replace(/\/+$/, "") || "/";
                const isActive = currentPath === linkPath;
                return (
                  <li>
                    <a
                      href={link.href}
                      aria-current={isActive ? "page" : undefined}
                      class:list={[
                        "block px-2 py-0 text-[3rem] leading-none tracking-tight focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white",
                        isActive
                          ? "font-bold text-white"
                          : "font-extralight text-stone-200",
                      ]}
                    >
                      {link.label}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </nav>
      </aside>

      <div
        class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
        style="background-image:url('/map/marikina_2k.png');"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-0 z-[5] bg-[linear-gradient(180deg,rgba(183,82,24,0.28)_0%,rgba(128,37,12,0.4)_44%,rgba(18,5,2,0.86)_74%,rgba(0,0,0,0.99)_100%)]"
        aria-hidden="true"
      >
      </div>

      <MobileTopNavbar
        leftAction={{
          type: "button",
          icon: "menu",
          ariaLabel: "Open navigation menu",
          id: "legacy-menu-toggle",
          controls: "legacy-mobile-sidebar",
          expanded: "false",
          className: "rounded-md cursor-pointer text-black",
        }}
        rightAction={{
          type: "button",
          icon: "search",
          ariaLabel: "Search store products",
          className: "rounded-md text-black",
        }}
        centerImageSrc="/Logo/brand.webp"
        centerImageAlt="Sole of Marikina"
        centerImageClass="h-14 w-auto max-w-[220px] object-contain sm:h-22 sm:max-w-[260px]"
        containerClass="sticky top-0 z-40 grid grid-cols-[1fr_auto_1fr] items-center bg-transparent px-6 pt-5 pb-3 text-black sm:px-8 sm:pt-6 sm:pb-3"
      />

      <main
        class="relative z-20 mx-auto w-full max-w-[430px] px-6 pb-16 pt-8 sm:px-8 sm:pb-20 sm:pt-10 md:max-w-3xl lg:max-w-5xl lg:px-10"
      >
        <div class="space-y-7 sm:space-y-8">
          <p
            class="text-lg leading-relaxed font-semibold text-white/95 sm:text-xl md:text-base lg:text-lg"
          >
            The Marikina shoe industry began in 1887 when Don Laureano Guevara,
            known as Kapitan Moy, disassembled a pair of imported British shoes
            to study their construction. Alongside local residents, he
            replicated the design using local materials and taught the craft to
            his neighbors, establishing a new livelihood for the community. By
            the mid-20th century, Marikina earned the title "Shoe Capital of the
            Philippines," producing the vast majority of the country&apos;s
            footwear and even reaching international markets like New
            York&apos;s Fifth Avenue.
          </p>

          <div
            class="grid grid-cols-[minmax(0,1fr)_9.5rem] items-end gap-4 sm:grid-cols-[minmax(0,1fr)_11.5rem] sm:gap-5 md:grid-cols-[minmax(0,1fr)_210px] lg:grid-cols-[minmax(0,1fr)_250px]"
          >
            <div class="space-y-3 self-center">
              <h1
                class="text-3xl leading-[0.9] font-extrabold tracking-[-0.02em] text-white sm:text-4xl md:text-3xl lg:text-4xl"
              >
                Don Laureno<br />Guevara
              </h1>
              <p
                class="text-sm leading-tight font-semibold text-white/90 sm:text-lg md:text-sm lg:text-base"
              >
                July 4, 1851 – December 30, 1891
              </p>
              <p
                class="text-md leading-tight font-medium text-white/88 sm:text-xl md:text-base lg:text-lg"
              >
                Founder of the Shoe Marikina Industry
              </p>
            </div>
            <figure>
              <img
                src={donLaureanoImage}
                alt="Don Laureano Guevara portrait"
                loading="lazy"
                decoding="async"
                class="w-full rounded-2xl object-cover"
              />
            </figure>
          </div>

          <p
            class="text-sm text-right italic text-white/85 sm:text-base md:text-sm lg:text-base"
          >
            Source: Philippine Cultural Education
          </p>

          <p
            class="text-lg leading-relaxed font-semibold text-white/95 sm:text-xl md:text-base lg:text-lg"
          >
            Kapitan Moy sparked a pioneering craftsmanship that quickly evolved
            from a single experimental pair of shoes into a vital source of
            income for the entire community. By the turn of the century, the
            town&apos;s skilled artisans had perfected their techniques,
            transforming the area into a premier manufacturing center.
          </p>

          <figure class="mx-auto w-full max-w-4xl">
            <img
              src={marikinaLegacyImageOne}
              alt="Historic Marikina shoemaking workshop"
              loading="lazy"
              decoding="async"
              class="w-full rounded-2xl object-cover"
            />
            <figcaption
              class="mt-3 text-center text-sm italic font-semibold text-white/80 sm:text-base md:text-sm lg:text-base"
            >
              Source: Marikina Tourism Department
            </figcaption>
          </figure>

          <p
            class="text-lg leading-relaxed font-semibold text-white/95 sm:text-xl md:text-base lg:text-lg"
          >
            Throughout the 20th century, the city entered its golden age as
            expertise was passed down through generations, building a global
            reputation for both resilience and style. At its peak, local
            workshops produced millions of pairs annually, turning Filipino
            craftsmanship into a profound point of national pride.
          </p>

          <p
            class="text-lg leading-relaxed font-semibold text-white/95 sm:text-xl md:text-base lg:text-lg"
          >
            Despite a significant downturn caused by the influx of global
            imports in the late 1900s, the community&apos;s resilient spirit
            remained intact. Craftsmen successfully pivoted from mass production
            toward a more specialized, artisanal approach. This strategic shift
            preserved the core traditions of the trade while opening doors for
            modern innovation in design and materials.
          </p>

          <figure class="mx-auto w-full max-w-4xl">
            <img
              src={marikinaLegacyImageTwo}
              alt="Shoemaker in a traditional Marikina workshop"
              loading="lazy"
              decoding="async"
              class="w-full rounded-2xl object-cover"
            />
            <figcaption
              class="mt-3 text-center text-sm italic font-semibold text-white/80 sm:text-base md:text-sm lg:text-base"
            >
              Source: Marikina Tourism Department
            </figcaption>
          </figure>

          <p
            class="text-lg leading-relaxed font-semibold text-white/95 sm:text-xl md:text-base lg:text-lg"
          >
            Today, the city&apos;s shoemaking heritage remains a central part of
            its identity, supported by local government initiatives and cultural
            landmarks like the Shoe Museum.
          </p>

          <figure class="mx-auto w-full max-w-4xl">
            <img
              src={shoeMuseumImage}
              alt="Marikina Shoe Museum interior"
              loading="lazy"
              decoding="async"
              class="w-full rounded-2xl object-cover"
            />
            <figcaption
              class="mt-3 text-center text-sm italic font-semibold text-white/80 sm:text-base md:text-sm lg:text-base"
            >
              Source: Marikina Shoe Museum
            </figcaption>
          </figure>

          <p
            class="text-xl leading-relaxed font-semibold text-white/95 sm:text-2xl md:text-lg lg:text-xl"
          >
            Sole of Marikina is a creative initiative dedicated to revitalizing
            and celebrating the rich heritage of the Philippines&apos; shoe
            capital. By bridging the gap between traditional craftsmanship and
            modern design, the project serves as a platform to uplift local
            artisans and showcase the enduring quality of Marikina-made
            footwear. Through its focus on storytelling and community-led
            innovation, it aims to ensure that the city&apos;s shoemaking legacy
            continues to walk forward into the future.
          </p>

          <div class="mt-10 flex justify-center sm:mt-12">
            <a
              href="/journey"
              class="inline-flex min-w-[13.5rem] items-center justify-center rounded-full border border-white/75 bg-white px-10 py-2.5 text-2xl font-semibold text-[#191511] transition hover:bg-white/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white md:px-8 md:py-2 md:text-xl lg:px-10 lg:py-2.5 lg:text-2xl"
            >
              Start The Journey
            </a>
          </div>
        </div>
      </main>
    </section>

    <Footer />
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    if (window.__somLegacyMenuInitialized) return;
    window.__somLegacyMenuInitialized = true;

    let cleanup = () => {};

    const init = () => {
      cleanup();

      const openButton = document.getElementById("legacy-menu-toggle");
      const closeButton = document.getElementById("legacy-menu-close");
      const overlay = document.getElementById("legacy-menu-overlay");
      const sidebar = document.getElementById("legacy-mobile-sidebar");
      if (!openButton || !closeButton || !overlay || !sidebar) return;

      const getFocusable = () =>
        sidebar.querySelectorAll("a[href], button:not([disabled])");

      const openMenu = () => {
        openButton.setAttribute("aria-expanded", "true");
        sidebar.classList.remove("-translate-x-full");
        sidebar.classList.add("translate-x-0");
        sidebar.setAttribute("aria-hidden", "false");
        overlay.classList.remove("opacity-0", "pointer-events-none");
        overlay.classList.add("opacity-100");
        document.body.classList.add("overflow-hidden");

        const firstFocusable = getFocusable()[0];
        if (firstFocusable instanceof HTMLElement) firstFocusable.focus();
      };

      const closeMenu = () => {
        openButton.setAttribute("aria-expanded", "false");
        sidebar.classList.remove("translate-x-0");
        sidebar.classList.add("-translate-x-full");
        sidebar.setAttribute("aria-hidden", "true");
        overlay.classList.remove("opacity-100");
        overlay.classList.add("opacity-0", "pointer-events-none");
        document.body.classList.remove("overflow-hidden");
      };

      const onOverlayClick = () => closeMenu();
      const onDocumentKeydown = (event) => {
        if (event.key === "Escape") closeMenu();
      };

      const sidebarLinks = Array.from(sidebar.querySelectorAll("a[href]"));
      const sidebarLinkHandlers = sidebarLinks.map((link) => {
        const onClick = () => closeMenu();
        link.addEventListener("click", onClick);
        return { link, onClick };
      });

      openButton.addEventListener("click", openMenu);
      closeButton.addEventListener("click", closeMenu);
      overlay.addEventListener("click", onOverlayClick);
      document.addEventListener("keydown", onDocumentKeydown);

      closeMenu();

      cleanup = () => {
        document.body.classList.remove("overflow-hidden");
        openButton.removeEventListener("click", openMenu);
        closeButton.removeEventListener("click", closeMenu);
        overlay.removeEventListener("click", onOverlayClick);
        document.removeEventListener("keydown", onDocumentKeydown);
        sidebarLinkHandlers.forEach(({ link, onClick }) => {
          link.removeEventListener("click", onClick);
        });
      };
    };

    init();
    document.addEventListener("astro:page-load", init);
  })();
</script>
