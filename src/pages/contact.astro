---
import Footer from "@/components/Footer.astro";
import MobileTopNavbar from "@/components/MobileTopNavbar.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | Sole of Marikina">
  <div class="min-h-screen bg-[#efe8df] text-[#1a130e]">
    <section class="relative">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(58%_45%_at_50%_0%,rgba(140,82,45,0.18)_0%,rgba(140,82,45,0)_100%),linear-gradient(180deg,rgba(255,255,255,0.4)_0%,rgba(239,232,223,1)_62%)]"
        aria-hidden="true"
      ></div>

      <MobileTopNavbar
        leftAction={{
          type: "link",
          icon: "move-left",
          ariaLabel: "Back to homepage",
          href: "/",
          dynamicBack: true,
          className: "rounded-md",
        }}
        rightAction={{
          type: "button",
          icon: "search",
          ariaLabel: "Search store products",
          className: "rounded-md",
        }}
        centerImageSrc="/Logo/brand.webp"
        centerImageAlt="Sole of Marikina"
        centerImageClass="h-16 w-auto max-w-xs object-contain sm:h-16"
        containerClass="sticky top-0 z-40 grid grid-cols-[1fr_auto_1fr] items-center border-b border-black/5 bg-[#efe8df]/90 px-6 pt-5 pb-3 text-black backdrop-blur-md sm:px-8 sm:pt-6 sm:pb-3"
      />

      <main class="relative z-10 mx-auto w-full max-w-[430px] px-6 pb-16 sm:px-8 md:max-w-3xl lg:max-w-5xl lg:px-10">
        <header class="pt-6 sm:pt-8 md:pt-10">
          <p class="text-xs font-semibold tracking-[0.24em] uppercase text-[#7a5436] sm:text-sm">
            Contact Template
          </p>
          <h1 class="mt-3 max-w-[10ch] text-4xl leading-[0.9] font-extrabold tracking-[-0.02em] text-[#2a1a11] sm:text-4xl md:text-5xl lg:text-6xl">
            Let&apos;s Connect
          </h1>
          <p class="mt-5 max-w-3xl text-sm leading-relaxed font-medium text-black/70 sm:text-base md:text-lg">
            This is a boilerplate Contact page. Replace the fields and destination details once your actual
            contact flow and messaging are finalized.
          </p>
        </header>

        <section class="mt-10 grid gap-5 sm:mt-12 lg:grid-cols-[0.9fr_1.1fr]">
          <aside class="rounded-3xl border border-[#3a2416] bg-[#2b1b11] p-6 text-white shadow-xs sm:p-8">
            <p class="text-xs font-semibold tracking-[0.18em] uppercase text-[#d8a370] sm:text-sm">
              Contact Channels
            </p>

            <div class="mt-4 space-y-4 text-sm sm:text-base">
              <div class="rounded-xl border border-white/15 bg-white/5 px-4 py-3">
                <p class="font-semibold text-white">Email</p>
                <p class="mt-1 font-medium text-white/80">hello@placeholder.com</p>
              </div>
              <div class="rounded-xl border border-white/15 bg-white/5 px-4 py-3">
                <p class="font-semibold text-white">Phone</p>
                <p class="mt-1 font-medium text-white/80">+63 000 000 0000</p>
              </div>
              <div class="rounded-xl border border-white/15 bg-white/5 px-4 py-3">
                <p class="font-semibold text-white">Address</p>
                <p class="mt-1 font-medium text-white/80">Marikina City, Philippines</p>
              </div>
            </div>
          </aside>

          <article class="rounded-3xl border border-black/10 bg-white/86 p-6 shadow-sm sm:p-8">
            <p class="text-xs font-semibold tracking-[0.18em] uppercase text-[#8e6340] sm:text-sm">
              Send a Message
            </p>
            <form class="mt-4 grid gap-4">
              <label class="grid gap-2">
                <span class="text-sm font-semibold text-black/70">Full Name</span>
                <input
                  type="text"
                  placeholder="Your name"
                  class="h-11 rounded-lg border border-black/15 bg-transparent px-3 text-sm font-medium outline-none transition focus-visible:border-black/35 focus-visible:ring-2 focus-visible:ring-black/15 sm:text-base"
                />
              </label>
              <label class="grid gap-2">
                <span class="text-sm font-semibold text-black/70">Email Address</span>
                <input
                  type="email"
                  placeholder="you@email.com"
                  class="h-11 rounded-lg border border-black/15 bg-transparent px-3 text-sm font-medium outline-none transition focus-visible:border-black/35 focus-visible:ring-2 focus-visible:ring-black/15 sm:text-base"
                />
              </label>
              <label class="grid gap-2">
                <span class="text-sm font-semibold text-black/70">Message</span>
                <textarea
                  rows={5}
                  placeholder="Tell us about your inquiry..."
                  class="rounded-lg border border-black/15 bg-transparent px-3 py-2 text-sm font-medium outline-none transition focus-visible:border-black/35 focus-visible:ring-2 focus-visible:ring-black/15 sm:text-base"
                ></textarea>
              </label>
              <button
                type="button"
                class="mt-1 inline-flex items-center justify-center rounded-full bg-black px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-black/85 sm:py-3 sm:text-base"
              >
                Send Inquiry
              </button>
            </form>
          </article>
        </section>
      </main>
    </section>

    <Footer />
  </div>
</BaseLayout>
