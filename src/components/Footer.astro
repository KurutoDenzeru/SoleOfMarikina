---
import { ArrowRight } from "lucide-react";

type Props = {
  brandName?: string;
  brandImage?: string;
  contactEmail?: string;
  location?: string;
  newsletterTitle?: string;
  newsletterDescription?: string;
  year?: number;
  onSubscribe?: string | null | undefined;
};

const {
  brandName = "Sole of Marikina",
  brandImage = "/Logo/brand.webp",
  contactEmail = "yapakkolektibegmail.com",
  location = "05 Samson Road, Caloocan City, Metro Manila, Philippines",
  newsletterTitle = "Step with us",
  newsletterDescription = "Share your store details, promotions, or brand content with your customers.",
  year = new Date().getFullYear(),
  onSubscribe,
} = Astro.props;
---

<footer class="bg-[#606060] text-white">
  <div class="mx-auto w-full px-6 py-12 md:px-10 md:py-16 lg:px-16">
    {/* Brand Logo */}
    <div class="mb-12 flex items-center gap-3">
      <img
        src={brandImage}
        alt={brandName}
        class="h-12 w-12 object-contain md:h-14 md:w-14"
      />
      <div class="space-y-0">
        <p class="text-base font-bold uppercase leading-tight tracking-tight md:text-lg">
          Sole of
        </p>
        <p class="text-base font-bold uppercase leading-tight tracking-tight md:text-lg">
          Marikina
        </p>
      </div>
    </div>

    {/* Main Content Grid - Mobile Stack, Desktop 3 Columns */}
    <div class="mb-12 grid gap-8 md:grid-cols-3 md:gap-12">
      {/* Contact Section */}
      <div class="space-y-4">
        <h3 class="text-lg font-bold leading-none tracking-tight md:text-xl">
          Contact
        </h3>
        <p class="text-sm leading-relaxed text-white/90 md:text-base">
          {contactEmail}
        </p>
      </div>

      {/* Location Section */}
      <div class="space-y-4">
        <h3 class="text-lg font-bold leading-none tracking-tight md:text-xl">
          Location
        </h3>
        <p class="text-sm leading-relaxed text-white/90 md:text-base">
          {location}
        </p>
      </div>

      {/* Step With Us Section */}
      <div class="space-y-4">
        <h3 class="text-lg font-bold leading-none tracking-tight md:text-xl">
          {newsletterTitle}
        </h3>
        <p class="text-sm leading-relaxed text-white/90 md:text-base">
          {newsletterDescription}
        </p>

        {/* Email Input Form */}
        <form
          onsubmit={onSubscribe}
          class="flex h-12 w-full items-center rounded-full border border-white/70 bg-transparent px-4 md:h-14 md:px-6"
        >
          <label for="footer-email" class="sr-only">Email</label>
          <input
            id="footer-email"
            type="email"
            placeholder="Email"
            class="flex-1 bg-transparent text-sm text-white placeholder:text-white/70 focus:outline-none md:text-base"
          />
          <button
            type="submit"
            aria-label="Submit email"
            class="ml-2 inline-flex h-8 w-8 items-center justify-center bg-white/10 rounded-full text-white transition hover:bg-white/20 md:h-10 md:w-10"
          >
            <ArrowRight className="h-5 w-5 md:h-6 md:w-6" />
          </button>
        </form>
      </div>
    </div>

    {/* Copyright */}
    <div class="border-t border-white/20 pt-8 text-center">
      <p class="text-sm text-white/90 md:text-base">
        © {year}, <a href="#" class="underline underline-offset-4">{brandName}</a>
      </p>
    </div>
  </div>
</footer>
