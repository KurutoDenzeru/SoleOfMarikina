---
import { ArrowRight } from "lucide-react";

type Props = {
  brandName?: string;
  brandImage?: string;
  contactEmail?: string;
  location?: string;
  newsletterTitle?: string;
  newsletterDescription?: string;
  year?: number;
  onSubscribe?: string | null | undefined;
};

const {
  brandName = "Sole of Marikina",
  brandImage = "/Logo/footer.webp",
  contactEmail = "yapakkolektib@gmail.com",
  location = "05 Samson Road, Caloocan City, Metro Manila, Philippines",
  newsletterTitle = "Step with us",
  newsletterDescription = "Share your store details, promotions, or brand content with your customers.",
  year = new Date().getFullYear(),
  onSubscribe,
} = Astro.props;
---

<footer class="bg-[#0A0300] text-white">
  <div class="mx-auto w-full px-6 py-12 md:px-10 md:py-16 lg:px-16">
    {/* Brand Logo */}
    <div class="mb-6">
      <img
        src={brandImage}
        alt={brandName}
        class="h-16 w-auto object-contain md:h-18 md:w-auto filter invert"
      />
    </div>

    {/* Main Content Grid - 2 columns on mobile and above */}
    <div class="mb-6 grid grid-cols-2 gap-4 md:gap-12">
      {/* Left Column: Contact + Location */}
      <div class="space-y-6 md:space-y-8">
        <div class="space-y-3">
          <h3 class="text-lg font-bold leading-none tracking-tight md:text-xl">
            Contact
          </h3>
          <p class="text-sm leading-relaxed text-white/90 md:text-base">
            {contactEmail}
          </p>
        </div>

        <div class="space-y-3">
          <h3 class="text-lg font-bold leading-none tracking-tight md:text-xl">
            Location
          </h3>
          <p class="text-sm leading-relaxed text-white/90 md:text-base">
            {location}
          </p>
        </div>
      </div>

      {/* Right Column: Step With Us */}
      <div class="space-y-4 self-start">
        <h3 class="text-lg font-bold leading-none tracking-tight md:text-xl">
          {newsletterTitle}
        </h3>
        <p class="text-sm leading-relaxed text-white/90 md:text-base">
          {newsletterDescription}
        </p>

        {/* Email Input Form */}
        <form
          onsubmit={onSubscribe}
          data-footer-email-form
          class="flex h-12 w-full items-center rounded-full border-2 border-white/80 bg-transparent px-5 md:h-14 md:px-6"
        >
          <label for="footer-email" class="sr-only">Email</label>
          <input
            id="footer-email"
            data-footer-email-input
            type="email"
            placeholder="Email"
            class="min-w-0 flex-1 bg-transparent text-sm text-white placeholder:text-white/70 focus:outline-none md:text-base"
          />
          <button
            type="submit"
            aria-label="Submit email"
            class="ml-3 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-white/90 transition hover:text-white"
          >
            <ArrowRight className="h-5 w-5 md:h-6 md:w-6" />
          </button>
        </form>
      </div>
    </div>

    {/* Copyright */}
    <div class="border-t border-white/20 pt-8 text-center">
      <p class="text-sm text-white/90 md:text-base">
        © {year}, <a href="#" class="underline underline-offset-4"
          >{brandName}</a
        >
      </p>
    </div>
  </div>
</footer>

<script is:inline>
  (() => {
    if (window.__somFooterEmailInitialized) return;
    window.__somFooterEmailInitialized = true;

    const init = () => {
      const forms = Array.from(document.querySelectorAll("[data-footer-email-form]"));
      const handlers = forms.map((form) => {
        const input = form.querySelector("[data-footer-email-input]");
        if (!(input instanceof HTMLInputElement)) return null;

        const onSubmit = (event) => {
          event.preventDefault();
          const senderEmail = input.value.trim();
          const to = "yapakkolektib@gmail.com";
          const subjectRaw = "Step with us";
          const subject = encodeURIComponent(subjectRaw);
          const bodyRaw =
            `Hello Yapak Kolektib,\n\nI would like to connect.\n\nMy email: ${senderEmail || "-"}\n`,
          const body = encodeURIComponent(bodyRaw);
          const gmailComposeUrl =
            `https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(to)}&su=${subject}&body=${body}`;
          const mailtoUrl = `mailto:${to}?subject=${subject}&body=${body}`;
          const opened = window.open(gmailComposeUrl, "_blank", "noopener,noreferrer");
          if (!opened) {
            window.location.assign(mailtoUrl);
          }
        };

        form.addEventListener("submit", onSubmit);
        return { form, onSubmit };
      });

      document.addEventListener(
        "astro:before-swap",
        () => {
          handlers.forEach((entry) => {
            if (!entry) return;
            entry.form.removeEventListener("submit", entry.onSubmit);
          });
        },
        { once: true },
      );
    };

    init();
    document.addEventListener("astro:page-load", init);
  })();
</script>
